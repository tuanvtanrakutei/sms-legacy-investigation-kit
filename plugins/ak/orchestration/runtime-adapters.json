{
  "version": "2.1",
  "required_operations": ["spawn", "message", "wait", "inspect", "interrupt"],
  "adapters": {
    "codex": {
      "spawn": "spawn_agent",
      "message": "send_message",
      "followup": "followup_task",
      "wait": "wait_agent",
      "inspect": "list_agents",
      "interrupt": "interrupt_agent",
      "close": null,
      "notes": "Respect the runtime concurrency limit. Reuse idle agents when possible."
    },
    "claude": {
      "spawn": "provider_task_or_subagent_tool",
      "message": "provider_message_operation",
      "wait": "provider_wait_or_task_output_operation",
      "inspect": "provider_task_status_operation",
      "interrupt": "provider_cancel_operation",
      "close": "provider_defined",
      "notes": "Resolve concrete tool names from the active Claude runtime before dispatch."
    },
    "generic": {
      "spawn": "required",
      "message": "required",
      "wait": "required",
      "inspect": "required",
      "interrupt": "required",
      "close": "optional",
      "notes": "Fail preflight if required operations cannot be mapped."
    }
  }
}
