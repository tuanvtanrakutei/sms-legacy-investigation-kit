{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Traceability Matrix Row",
  "type": "object",
  "required": ["run_id", "app_id", "task_id", "workflow_id", "step", "user_action", "screen", "vba_event", "processing", "data_target", "output", "evidence_ids"],
  "properties": {
    "run_id": {"type": "string"},
    "app_id": {"type": "string"},
    "task_id": {"type": "string"},
    "workflow_id": {"type": "string"},
    "step": {"type": "integer", "minimum": 1},
    "user_action": {"type": "string"},
    "screen": {"type": "string"},
    "vba_event": {"type": "string"},
    "processing": {"type": "string"},
    "data_target": {"type": "string"},
    "output": {"type": "string"},
    "evidence_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}}
  },
  "additionalProperties": false
}
